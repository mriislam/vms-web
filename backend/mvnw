# Apache Maven Wrapper startup shell script, version 3.3.2

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-.}"
if [ -z "$MAVEN_BASEDIR" ]; then
  WDIR="$PWD"
  while [ "$WDIR" != "/" ]; do
    if [ -d "$WDIR/.mvn" ]; then
      MAVEN_PROJECTBASEDIR="$WDIR"
      break
    fi
    WDIR=$(dirname "$WDIR")
  done
fi

WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ -r "$WRAPPER_PROPERTIES" ]; then
  WRAPPER_URL=$(grep "^wrapperUrl=" "$WRAPPER_PROPERTIES" | cut -d= -f2-)
  DISTRIBUTION_URL=$(grep "^distributionUrl=" "$WRAPPER_PROPERTIES" | cut -d= -f2-)
fi

if [ ! -e "$WRAPPER_JAR" ]; then
  if command -v curl > /dev/null; then
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL" 2>/dev/null || true
  elif command -v wget > /dev/null; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL" 2>/dev/null || true
  fi
fi

if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
else
  JAVACMD="java"
fi

if [ -e "$WRAPPER_JAR" ]; then
  exec "$JAVACMD" \
    $MAVEN_OPTS \
    -classpath "$WRAPPER_JAR" \
    "-Dmaven.home=$MAVEN_PROJECTBASEDIR" \
    "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"
else
  exec mvn "$@"
fi
