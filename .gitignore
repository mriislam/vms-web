# ── Node / Frontend ──────────────────────────────────────────────
node_modules/
dist/
frontend/dist/
frontend/.vite/
frontend/node_modules/

# Environment / secrets — keep .example files
.env
.env.local
.env.*.local
.env.production
.env.development
frontend/.env
frontend/.env.*
!frontend/.env.example
!.env.example

# ── Java / Maven / Spring Boot ───────────────────────────────────
backend/target/
*.class
*.jar
*.war
*.ear
*.iml
backend/.mvn/wrapper/maven-wrapper.jar

# Spring Boot sensitive config — use application.properties.example
backend/src/main/resources/application.properties
backend/src/main/resources/application-*.properties
!backend/src/main/resources/application.properties.example
backend/src/main/resources/*.p12
backend/src/main/resources/*.jks
backend/src/main/resources/*.pfx

